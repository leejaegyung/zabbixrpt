# Zabbix Reporter — Docker Compose 환경변수 예시
# backend/.env 와 별개로, compose 레벨에서 주입할 값.

# Zabbix API (api_jsonrpc.php 전체 URL)
ZABBIX_API_URL=http://your-zabbix-server/zabbix/api_jsonrpc.php

# (선택) 서버에 보관할 API 토큰. 비우면 요청별 토큰 전달 모드.
ZABBIX_API_TOKEN=

# Laravel
APP_KEY=
APP_ENV=production
APP_DEBUG=false

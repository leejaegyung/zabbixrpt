# Docker Compose environment example.
# Copy this file to zabbix-reporter/.env before running docker compose.
# Do not copy this file into backend/.env for Docker deployment.

# Public port for the web container.
WEB_PORT=8080

# Zabbix API full URL.
ZABBIX_API_URL=http://your-zabbix-server/zabbix/api_jsonrpc.php

# Optional fixed Zabbix API token.
# Leave empty if the app should use request-provided credentials.
ZABBIX_API_TOKEN=

# Allow users to provide the Zabbix API URL from the UI/request.
ZABBIX_ALLOW_REQUEST_URL=true

# Laravel runtime settings.
APP_KEY=
APP_ENV=production
APP_DEBUG=false
